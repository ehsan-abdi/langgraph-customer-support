# --- LLM Provider Configuration ---
# Choose 'openai' or 'groq' in your application configuration
OPENAI_API_KEY="sk-your-openai-api-key-here"
GROQ_API_KEY="gsk_your-groq-api-key-here"

# --- Jira API Integration (Optional) ---
JIRA_SERVER="https://your-domain.atlassian.net"
JIRA_EMAIL="admin@your-domain.com"
JIRA_API_TOKEN="your-jira-api-token"
JIRA_PROJECT_KEY="AURA"

# --- AWS Bedrock Credentials (Required only for `src/bedrock_app/`) ---
AWS_ACCESS_KEY_ID="AKIA_YOUR_AWS_ACCESS_KEY"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
AWS_DEFAULT_REGION="us-east-1"

# --- Application Server Settings ---
PORT=8000
HOST="0.0.0.0"
ENVIRONMENT="development"
